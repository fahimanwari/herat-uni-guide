# Database
DB_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://uniguide:change-me@db:5432/uniguide

# Redis
REDIS_URL=redis://redis:6379/0

# Security
JWT_SECRET=change-me-long-random

# AI (start with free Gemini, switch to OpenRouter for production)
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_API_KEY=your-gemini-key-here

# Storage
STORAGE_PROVIDER=local

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:4000,https://guide.hu.edu.af

# cPanel backup (optional — for nightly FTP backup)
CPANEL_FTP_HOST=
CPANEL_FTP_USER=
CPANEL_FTP_PASS=

# Database
DB_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://uniguide:change-me@db:5432/uniguide

# Redis
REDIS_URL=redis://redis:6379/0

# Security
JWT_SECRET=change-me-long-random

# AI Provider (groq = free & fast for dev; gemini = free tier for prod; openrouter = pay-as-you-go)
# Switch provider by changing AI_PROVIDER — no code changes needed
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
AI_API_KEY=your-groq-api-key-here
# Alternative: AI_PROVIDER=gemini / AI_MODEL=gemini-2.5-flash
# Alternative: AI_PROVIDER=openrouter / AI_MODEL=google/gemini-2.5-flash

# Storage
STORAGE_PROVIDER=local

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:4000,https://guide.hu.edu.af

# cPanel backup (optional — for nightly FTP backup)
CPANEL_FTP_HOST=
CPANEL_FTP_USER=
CPANEL_FTP_PASS=
